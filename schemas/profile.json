{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/geronimo-iia/llm-wiki/schemas/v0.5.0/profile.json",
  "title": "Profile memory type",
  "description": "Operator constitution: identity, hard rules, style, stack, and constraints loaded every session.",
  "type": "object",
  "required": ["title", "type", "section", "priority", "status"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Display name"
    },
    "type": {
      "type": "string",
      "const": "profile",
      "description": "Page type"
    },
    "section": {
      "type": "string",
      "description": "Profile section",
      "enum": ["rules", "identity", "style", "stack", "constraints"]
    },
    "priority": {
      "type": "string",
      "description": "Enforcement level",
      "enum": ["hard", "soft"]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle state",
      "enum": ["active", "superseded"]
    },
    "supersedes": {
      "type": "string",
      "description": "Slug of the profile page this entry replaces"
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 date"
    },
    "last_verified": {
      "type": "string",
      "description": "ISO 8601 date"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "x-wiki-types": {
    "profile": "Operator profile memory — rules, identity, style, stack, constraints"
  },
  "x-graph-edges": {
    "supersedes": {
      "relation": "supersedes",
      "direction": "outgoing",
      "target_types": ["profile"]
    }
  },
  "additionalProperties": true
}
